# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJ_your_anon_public_key_here

# ── PDF Server ────────────────────────────────────────────────────────────────
# The PDF server (server/pdf-server.js) is a separate Express + Puppeteer
# process that CANNOT run on Vercel serverless.
# Deploy it separately (Railway, Render, or any VPS) and set this URL.
#
# Local development:   leave empty or use http://localhost:3001
# Production:          https://your-pdf-server.railway.app  (no trailing slash)
VITE_PDF_SERVER_URL=http://localhost:3001
